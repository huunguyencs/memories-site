---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getAllMemories, getMemoryBySlug } from "../../lib/memories";

export function getStaticPaths() {
  const memories = getAllMemories();
  return memories.map((memory) => ({
    params: { slug: memory.slug },
  }));
}

const { slug } = Astro.params;
const memory = getMemoryBySlug(slug as string);

if (!memory) {
  return Astro.redirect("/");
}
---

<BaseLayout title={`${memory.title} — Memories`} description={`${memory.title} ${memory.dateDisplay}`}>
  <!-- Slideshow fullscreen view -->
  <div
    id="slideshow"
    class="fixed inset-0 z-50 bg-[var(--color-surface-dark)] flex flex-col"
    data-photos={JSON.stringify(memory.photos)}
    data-title={memory.title}
    data-date={memory.dateDisplay}
  >
    <!-- Progress bar -->
    <div class="absolute top-0 left-0 right-0 z-30 flex gap-1 px-3 pt-3 md:px-6 md:pt-5" id="progress-bar">
      {
        memory.photos.map((_, i) => (
          <div class="flex-1 h-[3px] rounded-full bg-white/20 overflow-hidden">
            <div
              class="progress-segment h-full bg-white/90 rounded-full"
              data-index={i}
              style="width: 0%"
            />
          </div>
        ))
      }
    </div>

    <!-- Top controls -->
    <div
      id="slideshow-controls"
      class="absolute top-0 left-0 right-0 z-20 flex items-center justify-between px-4 pt-8 md:px-8 md:pt-10 transition-opacity duration-300"
    >
      <div></div>
      <div class="flex items-center gap-3">
        {memory.music && (
          <button
            id="btn-music"
            class="p-2 rounded-full bg-white/10 hover:bg-white/20 transition-colors duration-200 cursor-pointer backdrop-blur-sm"
            aria-label="Toggle music"
          >
            <svg id="icon-music-off" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M9 18V5l12-2v13" />
              <circle cx="6" cy="18" r="3" />
              <circle cx="18" cy="16" r="3" />
              <line x1="2" y1="2" x2="22" y2="22" stroke-width="2" />
            </svg>
            <svg id="icon-music-on" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="hidden">
              <path d="M9 18V5l12-2v13" />
              <circle cx="6" cy="18" r="3" />
              <circle cx="18" cy="16" r="3" />
            </svg>
          </button>
        )}
        <button
          id="btn-grid"
          class="p-2 rounded-full bg-white/10 hover:bg-white/20 transition-colors duration-200 cursor-pointer backdrop-blur-sm"
          aria-label="Grid view"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5" stroke-linecap="round">
            <rect x="3" y="3" width="7" height="7" rx="1" />
            <rect x="14" y="3" width="7" height="7" rx="1" />
            <rect x="3" y="14" width="7" height="7" rx="1" />
            <rect x="14" y="14" width="7" height="7" rx="1" />
          </svg>
        </button>
        <a
          href="/memories-site/"
          id="btn-close"
          class="p-2 rounded-full bg-white/10 hover:bg-white/20 transition-colors duration-200 cursor-pointer backdrop-blur-sm"
          aria-label="Close"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round">
            <line x1="18" y1="6" x2="6" y2="18" />
            <line x1="6" y1="6" x2="18" y2="18" />
          </svg>
        </a>
      </div>
    </div>

    <!-- Slides container -->
    <div id="slides" class="absolute inset-0 overflow-hidden">
      {
        memory.photos.map((photo, i) => (
          <div
            class="slide absolute inset-0 flex items-center justify-center"
            data-slide-index={i}
            style={`opacity: ${i === 0 ? 1 : 0}; z-index: ${i === 0 ? 1 : 0}`}
          >
            <img
              src={photo}
              alt={`${memory.title} — ${i + 1}`}
              class="slide-img w-full h-full object-contain"
              loading={i < 2 ? "eager" : "lazy"}
              style={`view-transition-name: ${i === 0 ? `memory-${memory.slug}` : "none"}; animation: ken-burns-${(i % 4) + 1} 8s ease-out forwards; animation-play-state: ${i === 0 ? "running" : "paused"};`}
            />
          </div>
        ))
      }
    </div>

    <!-- Bottom info -->
    <div
      id="slideshow-info"
      class="absolute bottom-0 left-0 right-0 z-20 px-5 pb-8 md:px-8 md:pb-10 transition-opacity duration-300"
    >
      <div class="bg-gradient-to-t from-black/50 to-transparent absolute inset-0 -top-20 pointer-events-none"></div>
      <div class="relative">
        <h1 class="font-heading text-3xl md:text-5xl font-semibold text-white leading-tight">
          {memory.title}
        </h1>
        <p class="mt-1.5 font-body text-sm md:text-base text-white/60 tracking-wide">
          {memory.dateDisplay}
        </p>
      </div>
    </div>

    <!-- Navigation areas (invisible) -->
    <div id="nav-prev" class="absolute left-0 top-0 w-1/3 h-full z-10 cursor-pointer" aria-label="Previous"></div>
    <div id="nav-next" class="absolute right-0 top-0 w-1/3 h-full z-10 cursor-pointer" aria-label="Next"></div>
    <div id="nav-center" class="absolute left-1/3 top-0 w-1/3 h-full z-10 cursor-pointer" aria-label="Pause/Play"></div>

    <!-- Background music (per-memory) -->
    {memory.music && (
      <audio id="bg-music" loop preload="auto">
        <source src={memory.music} type="audio/mpeg" />
      </audio>
    )}
  </div>

  <!-- Grid view (hidden by default) -->
  <div id="grid-view" class="fixed inset-0 z-50 bg-[var(--color-surface-dark)] overflow-y-auto hidden">
    <div class="sticky top-0 z-10 flex items-center justify-between px-5 py-4 md:px-8 md:py-6 bg-gradient-to-b from-[var(--color-surface-dark)] via-[var(--color-surface-dark)] to-transparent">
      <div>
        <h2 class="font-heading text-2xl md:text-3xl font-semibold text-white">{memory.title}</h2>
        <p class="font-body text-sm text-white/50 mt-0.5">{memory.dateDisplay} &middot; {memory.photos.length} ảnh</p>
      </div>
      <div class="flex items-center gap-3">
        <button
          id="btn-slideshow"
          class="p-2 rounded-full bg-white/10 hover:bg-white/20 transition-colors duration-200 cursor-pointer"
          aria-label="Slideshow view"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <polygon points="5 3 19 12 5 21 5 3" />
          </svg>
        </button>
        <a
          href="/memories-site/"
          class="p-2 rounded-full bg-white/10 hover:bg-white/20 transition-colors duration-200 cursor-pointer"
          aria-label="Close"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round">
            <line x1="18" y1="6" x2="6" y2="18" />
            <line x1="6" y1="6" x2="18" y2="18" />
          </svg>
        </a>
      </div>
    </div>

    <div class="px-3 pb-8 md:px-6 md:pb-12 columns-2 md:columns-3 gap-2 md:gap-3 space-y-2 md:space-y-3">
      {
        memory.photos.map((photo, i) => (
          <div
            class="grid-photo block overflow-hidden rounded-lg break-inside-avoid cursor-pointer group"
            data-photo-index={i}
          >
            <img
              src={photo}
              alt={`${memory.title} — ${i + 1}`}
              loading="lazy"
              decoding="async"
              class="w-full h-auto object-cover transition-transform duration-400 group-hover:scale-[1.03]"
              style={`animation: card-enter 0.4s ease-out ${i * 60}ms both`}
            />
          </div>
        ))
      }
    </div>
  </div>

  <!-- Lightbox overlay -->
  <div id="lightbox" class="fixed inset-0 z-[60] bg-black/95 hidden items-center justify-center backdrop-blur-sm">
    <!-- Close button -->
    <button
      id="lightbox-close"
      class="absolute top-4 right-4 z-10 p-2 rounded-full bg-white/10 hover:bg-white/20 transition-colors duration-200 cursor-pointer"
      aria-label="Close lightbox"
    >
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round">
        <line x1="18" y1="6" x2="6" y2="18" />
        <line x1="6" y1="6" x2="18" y2="18" />
      </svg>
    </button>

    <!-- Nav arrows -->
    <button
      id="lightbox-prev"
      class="absolute left-3 top-1/2 -translate-y-1/2 z-10 p-2 rounded-full bg-white/10 hover:bg-white/20 transition-colors duration-200 cursor-pointer"
      aria-label="Previous photo"
    >
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="15 18 9 12 15 6" />
      </svg>
    </button>
    <button
      id="lightbox-next"
      class="absolute right-3 top-1/2 -translate-y-1/2 z-10 p-2 rounded-full bg-white/10 hover:bg-white/20 transition-colors duration-200 cursor-pointer"
      aria-label="Next photo"
    >
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="9 6 15 12 9 18" />
      </svg>
    </button>

    <!-- Image -->
    <img
      id="lightbox-img"
      src=""
      alt=""
      class="max-w-[92vw] max-h-[90vh] object-contain select-none transition-opacity duration-300"
    />

    <!-- Counter -->
    <div id="lightbox-counter" class="absolute bottom-5 left-1/2 -translate-x-1/2 font-body text-sm text-white/50 tracking-wide"></div>
  </div>
</BaseLayout>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const slideshow = document.getElementById("slideshow");
    const gridView = document.getElementById("grid-view");
    const btnGrid = document.getElementById("btn-grid");
    const btnSlideshow = document.getElementById("btn-slideshow");
    const controls = document.getElementById("slideshow-controls");
    const info = document.getElementById("slideshow-info");
    const navPrev = document.getElementById("nav-prev");
    const navNext = document.getElementById("nav-next");
    const navCenter = document.getElementById("nav-center");
    const btnMusic = document.getElementById("btn-music");
    const iconMusicOn = document.getElementById("icon-music-on");
    const iconMusicOff = document.getElementById("icon-music-off");
    const bgMusic = document.getElementById("bg-music") as HTMLAudioElement | null;

    if (!slideshow) return;

    const photos: string[] = JSON.parse(slideshow.dataset.photos || "[]");
    const slides = document.querySelectorAll<HTMLElement>(".slide");
    const segments = document.querySelectorAll<HTMLElement>(".progress-segment");
    const totalSlides = photos.length;

    let current = 0;
    let playing = true;
    let timer: ReturnType<typeof setTimeout> | null = null;
    let progressAnimation: Animation | null = null;
    let controlsTimeout: ReturnType<typeof setTimeout> | null = null;
    const SLIDE_DURATION = 5000;

    function showSlide(index: number, direction: "next" | "prev" = "next") {
      slides.forEach((slide, i) => {
        const img = slide.querySelector<HTMLElement>(".slide-img");
        if (i === index) {
          slide.style.zIndex = "1";
          slide.style.opacity = "1";
          if (img) img.style.animationPlayState = "running";
        } else {
          slide.style.zIndex = "0";
          slide.style.opacity = "0";
          if (img) {
            img.style.animationPlayState = "paused";
            // Reset ken burns for reuse
            img.style.animation = "none";
            img.offsetHeight;
            img.style.animation = `ken-burns-${(i % 4) + 1} 8s ease-out forwards`;
            img.style.animationPlayState = "paused";
          }
        }
      });

      // Update progress segments
      segments.forEach((seg, i) => {
        if (i < index) {
          seg.style.width = "100%";
          seg.style.transition = "none";
        } else if (i > index) {
          seg.style.width = "0%";
          seg.style.transition = "none";
        }
      });

      // Animate current segment
      if (progressAnimation) progressAnimation.cancel();
      const currentSeg = segments[index];
      if (currentSeg && playing) {
        currentSeg.style.width = "0%";
        progressAnimation = currentSeg.animate(
          [{ width: "0%" }, { width: "100%" }],
          { duration: SLIDE_DURATION, fill: "forwards" }
        );
        progressAnimation.onfinish = () => {
          currentSeg.style.width = "100%";
          goNext();
        };
      } else if (currentSeg && !playing) {
        currentSeg.style.width = "0%";
      }

      current = index;
    }

    function goNext() {
      if (current < totalSlides - 1) {
        showSlide(current + 1, "next");
      } else {
        // Loop back
        showSlide(0, "next");
      }
    }

    function goPrev() {
      if (current > 0) {
        showSlide(current - 1, "prev");
      }
    }

    function togglePlay() {
      playing = !playing;
      if (playing) {
        showSlide(current);
      } else {
        if (progressAnimation) progressAnimation.pause();
      }
    }

    function showControls() {
      if (controls) controls.style.opacity = "1";
      if (info) info.style.opacity = "1";
      if (controlsTimeout) clearTimeout(controlsTimeout);
      controlsTimeout = setTimeout(() => {
        if (playing) {
          if (controls) controls.style.opacity = "0";
          if (info) info.style.opacity = "0";
        }
      }, 3000);
    }

    // Navigation
    navPrev?.addEventListener("click", (e) => {
      e.stopPropagation();
      goPrev();
      showControls();
    });

    navNext?.addEventListener("click", (e) => {
      e.stopPropagation();
      goNext();
      showControls();
    });

    navCenter?.addEventListener("click", (e) => {
      e.stopPropagation();
      togglePlay();
      showControls();
    });

    // Keyboard
    document.addEventListener("keydown", (e) => {
      if (gridView && !gridView.classList.contains("hidden")) return;
      if (e.key === "ArrowRight" || e.key === " ") {
        e.preventDefault();
        goNext();
        showControls();
      }
      if (e.key === "ArrowLeft") {
        goPrev();
        showControls();
      }
      if (e.key === "Escape") {
        window.location.href = "/memories-site/";
      }
    });

    // Mouse movement shows controls
    slideshow.addEventListener("mousemove", showControls);

    // Touch swipe
    let touchStartX = 0;
    let touchStartY = 0;

    slideshow.addEventListener("touchstart", (e) => {
      touchStartX = e.touches[0].clientX;
      touchStartY = e.touches[0].clientY;
    }, { passive: true });

    slideshow.addEventListener("touchend", (e) => {
      const dx = e.changedTouches[0].clientX - touchStartX;
      const dy = e.changedTouches[0].clientY - touchStartY;

      if (Math.abs(dx) > 50 && Math.abs(dx) > Math.abs(dy)) {
        if (dx < 0) goNext();
        else goPrev();
        showControls();
      } else if (dy > 80 && Math.abs(dy) > Math.abs(dx)) {
        // Swipe down to dismiss
        window.location.href = "/memories-site/";
      }
    }, { passive: true });

    // Music toggle
    let musicPlaying = false;

    function updateMusicIcon() {
      if (iconMusicOn && iconMusicOff) {
        iconMusicOn.classList.toggle("hidden", !musicPlaying);
        iconMusicOff.classList.toggle("hidden", musicPlaying);
      }
    }

    btnMusic?.addEventListener("click", (e) => {
      e.stopPropagation();
      if (!bgMusic) return;

      if (musicPlaying) {
        bgMusic.pause();
        musicPlaying = false;
      } else {
        bgMusic.volume = 0.3;
        bgMusic.play().catch(() => {
          // Autoplay blocked — will try again on next interaction
        });
        musicPlaying = true;
      }
      updateMusicIcon();
      showControls();
    });

    // Grid / Slideshow toggle
    btnGrid?.addEventListener("click", () => {
      if (slideshow) slideshow.style.display = "none";
      if (gridView) gridView.classList.remove("hidden");
      if (progressAnimation) progressAnimation.pause();
      playing = false;
      if (bgMusic && musicPlaying) bgMusic.pause();
    });

    btnSlideshow?.addEventListener("click", () => {
      if (slideshow) slideshow.style.display = "flex";
      if (gridView) gridView.classList.add("hidden");
      playing = true;
      showSlide(current);
      if (bgMusic && musicPlaying) bgMusic.play();
    });

    // ── Lightbox ──
    const lightbox = document.getElementById("lightbox");
    const lightboxImg = document.getElementById("lightbox-img") as HTMLImageElement | null;
    const lightboxClose = document.getElementById("lightbox-close");
    const lightboxPrev = document.getElementById("lightbox-prev");
    const lightboxNext = document.getElementById("lightbox-next");
    const lightboxCounter = document.getElementById("lightbox-counter");
    const gridPhotos = document.querySelectorAll<HTMLElement>(".grid-photo");
    let lightboxIndex = 0;

    function openLightbox(index: number) {
      lightboxIndex = index;
      if (!lightbox || !lightboxImg) return;
      lightboxImg.style.opacity = "0";
      lightboxImg.src = photos[index];
      lightboxImg.alt = `${slideshow.dataset.title} — ${index + 1}`;
      lightboxImg.onload = () => { lightboxImg.style.opacity = "1"; };
      if (lightboxCounter) lightboxCounter.textContent = `${index + 1} / ${photos.length}`;
      lightbox.classList.remove("hidden");
      lightbox.classList.add("flex");
    }

    function closeLightbox() {
      if (!lightbox) return;
      lightbox.classList.add("hidden");
      lightbox.classList.remove("flex");
    }

    function lightboxGo(dir: number) {
      const next = lightboxIndex + dir;
      if (next >= 0 && next < photos.length) openLightbox(next);
    }

    gridPhotos.forEach((el) => {
      el.addEventListener("click", () => {
        const idx = parseInt(el.dataset.photoIndex || "0", 10);
        openLightbox(idx);
      });
    });

    lightboxClose?.addEventListener("click", closeLightbox);
    lightboxPrev?.addEventListener("click", () => lightboxGo(-1));
    lightboxNext?.addEventListener("click", () => lightboxGo(1));

    lightbox?.addEventListener("click", (e) => {
      if (e.target === lightbox) closeLightbox();
    });

    document.addEventListener("keydown", (e) => {
      if (!lightbox || lightbox.classList.contains("hidden")) return;
      if (e.key === "Escape") closeLightbox();
      if (e.key === "ArrowLeft") lightboxGo(-1);
      if (e.key === "ArrowRight") lightboxGo(1);
    });

    // Lightbox touch swipe
    let lbTouchX = 0;
    lightbox?.addEventListener("touchstart", (e) => {
      lbTouchX = e.touches[0].clientX;
    }, { passive: true });
    lightbox?.addEventListener("touchend", (e) => {
      const dx = e.changedTouches[0].clientX - lbTouchX;
      if (Math.abs(dx) > 50) {
        if (dx < 0) lightboxGo(1);
        else lightboxGo(-1);
      }
    }, { passive: true });

    // Start
    showSlide(0);
    showControls();
  });
</script>
