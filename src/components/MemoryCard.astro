---
interface Props {
  title: string;
  slug: string;
  year: number;
  dateDisplay: string;
  cover: string;
  index: number;
  photoCount: number;
}

const { title, slug, year, dateDisplay, cover, index, photoCount } = Astro.props;
---

<a
  href={`/memories/${slug}/`}
  class="memory-card group relative block overflow-hidden rounded-2xl cursor-pointer"
  data-memory-year={year}
  style={`animation-delay: ${index * 60}ms`}
>
  <div class="aspect-[3/4] relative overflow-hidden">
    <img
      src={cover}
      alt={title}
      loading={index < 4 ? "eager" : "lazy"}
      decoding="async"
      class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 ease-out group-hover:scale-[1.04]"
      style={`view-transition-name: memory-${slug}`}
    />

    <!-- Gradient scrim -->
    <div
      class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/10 to-transparent opacity-80 group-hover:opacity-90 transition-opacity duration-300"
    >
    </div>

    <!-- Content -->
    <div class="absolute bottom-0 left-0 right-0 p-4 md:p-5">
      <h2 class="font-heading text-xl md:text-2xl font-semibold text-white leading-tight">
        {title}
      </h2>
      <div class="flex items-center gap-2 mt-1.5">
        <span class="font-body text-xs md:text-sm text-white/60 tracking-wide">
          {dateDisplay}
        </span>
        <span class="text-white/30">&#183;</span>
        <span class="font-body text-xs md:text-sm text-white/60 tracking-wide">
          {photoCount} ảnh
        </span>
      </div>
    </div>
  </div>
</a>

<style>
  .memory-card {
    animation: card-enter 0.5s ease-out both;
    box-shadow: 0 2px 8px rgba(26, 22, 20, 0.06);
    transition:
      transform 0.3s ease-out,
      box-shadow 0.3s ease-out;
  }

  .memory-card:hover {
    transform: translateY(-4px);
    box-shadow:
      0 12px 32px rgba(26, 22, 20, 0.12),
      0 4px 12px rgba(26, 22, 20, 0.06);
  }

  .memory-card:active {
    transform: translateY(-2px) scale(0.99);
  }
</style>
